# ==============================================================
# AluraAgente RAG — Variables de Entorno
# Copia este archivo a .env y completa tus valores reales.
# NUNCA subas .env a Git.
# ==============================================================

# ── REQUERIDO ─────────────────────────────────────────────────
# Clave de Anthropic para Claude 3.5 Haiku
# Obtén la tuya en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OPCIONAL ──────────────────────────────────────────────────
# Si prefieres embeddings de OpenAI en lugar de sentence-transformers local
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EMBEDDING_MODEL=text-embedding-3-small

# ── CONFIGURACIÓN DEL LLM ────────────────────────────────────
LLM_MODEL=claude-3-5-haiku-20241022
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096
MAX_RETRIES=3

# ── EMBEDDINGS LOCALES (default — sin costo) ─────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── RUTAS ────────────────────────────────────────────────────
DATA_DIR=data
VECTORSTORE_DIR=vectordb
CHARTS_DIR=charts

# ── RAG ──────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVER_K=5

# ── UI ───────────────────────────────────────────────────────
GRADIO_PORT=7860
GRADIO_SHARE=false
