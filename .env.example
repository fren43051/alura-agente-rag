# AluraAgente RAG — Variables de entorno
# Copia este archivo a .env y completa los valores
# cp .env.example .env

# ── REQUERIDO: Anthropic (Claude 3.5 Haiku) ───────────────────────
# Obtén tu API key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=tu_api_key_de_anthropic_aqui

# ── OPCIONAL: Configuración de la UI ─────────────────────────────
# Puerto del servidor Gradio (default: 7860)
PORT=7860

# Habilitar enlace público de Gradio (true/false)
GRADIO_SHARE=false

# ── OPCIONAL: Oracle Cloud Infrastructure (OCI) ───────────────────
# Para deploy en OCI. Ver documentación en docs/oci-deploy.md
# OCI_COMPARTMENT_ID=
# OCI_REGION=us-ashburn-1
# OCI_OBJECT_STORAGE_BUCKET=alura-agente-docs
