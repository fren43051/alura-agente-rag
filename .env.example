# ============================================
# AluraAgente RAG — Variables de Entorno
# Copiar a .env y completar con tus valores
# ============================================

# LLM Provider (elige uno)
OPENAI_API_KEY=sk-your-key-here
GOOGLE_API_KEY=your-gemini-key-here

# Modelo LLM
LLM_MODEL=gpt-4o-mini
# LLM_MODEL=gemini-1.5-flash   # alternativa Gemini

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=corporate_docs

# Documentos
DOCS_DIR=./docs/sample_docs

# App
APP_PORT=7860
APP_TITLE=AluraAgente RAG
DEBUG=false

# OCI (Oracle Cloud)
OCI_CONFIG_FILE=~/.oci/config
OCI_PROFILE=DEFAULT
