# AluraAgente RAG — Variables de Entorno
# Copia este archivo a .env y completa los valores
# cp .env.example .env

# ── REQUERIDO: Anthropic Claude 3.5 Haiku ────────────────────
# Obtén tu API key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OPCIONAL: Configuración del servidor ─────────────────────
# Puerto del servidor Gradio (default: 7860)
PORT=7860

# Compartir con URL pública de Gradio (true/false)
GRADIO_SHARE=false

# ── OPCIONAL: Embeddings (HuggingFace — no requiere API key) ──
# Modelo de embeddings multilingüe (se descarga automáticamente)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ── OPCIONAL: Oracle Cloud Infrastructure ────────────────────
# Para deploy en OCI Compute Instance
# OCI_COMPARTMENT_ID=ocid1.compartment.oc1...
# OCI_REGION=us-ashburn-1
